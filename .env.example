APP_NAME=Sistema Inteligente de Atención al Cliente
APP_VERSION=0.1.0
APP_ENV=local

API_HOST=127.0.0.1
API_PORT=3001

AI_MODE=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

MAX_INPUT_CHARS=2000
LOG_LEVEL=INFO
CORS_ORIGINS=*
DATABASE_URL=sqlite:///./app/data/customer_service.sqlite3
OPENAI_MAX_OUTPUT_TOKENS=500
OPENAI_TIMEOUT_SECONDS=30
AI_USE_OPENAI_ANALYSIS=false
AI_USE_OPENAI_REPLY=false
